# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Model Selection (customize per agent)
CREATOR_MODEL=gpt-4-turbo
CRITIC_MODEL=gpt-4-turbo
RADICAL_MODEL=gpt-4
SYNTHESIZER_MODEL=gpt-3.5-turbo
JUDGE_MODEL=gpt-4

# Temperature Settings (0.0 = deterministic, 1.0 = creative)
CREATOR_TEMPERATURE=0.8
CRITIC_TEMPERATURE=0.5
RADICAL_TEMPERATURE=0.9
SYNTHESIZER_TEMPERATURE=0.6
JUDGE_TEMPERATURE=0.3

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_agents
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Vector Store Configuration
VECTOR_DB_PATH=./data/vector_store

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info
